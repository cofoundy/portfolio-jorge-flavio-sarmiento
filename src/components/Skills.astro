---
import { siteConfig } from "../config";
---

<section id="skills" class="py-20 px-6" style="background-color: white">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-primary)] mb-10">Skills & Languages</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Technical Skills -->
      <div class="reveal stagger-1">
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-primary-dark)]/40 mb-4">Technical</h3>
        <div class="flex flex-wrap gap-2">
          {siteConfig.skills.technical.map(skill => (
            <span class="skill-hover px-3 py-1.5 rounded-lg text-sm font-medium bg-[var(--color-surface)] text-[var(--color-primary-dark)] border border-[var(--color-primary-light)]/20 hover:border-[var(--color-primary)]/40">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Languages -->
      <div class="reveal stagger-2">
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-primary-dark)]/40 mb-4">Languages</h3>
        <div class="space-y-3">
          {siteConfig.skills.languages.map(lang => (
            <div class="flex items-center justify-between py-2 px-4 rounded-lg bg-[var(--color-surface)]">
              <span class="text-sm font-semibold text-[var(--color-primary-dark)]">{lang.name}</span>
              <span class="text-xs font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/10 px-2.5 py-0.5 rounded-full">{lang.level}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
