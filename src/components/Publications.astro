---
import { siteConfig } from "../config";

const maxCitations = 10;
---

<section id="publications" class="py-20 px-6" style={`background-color: var(--color-primary-dark); color: white`}>
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-primary-light)] mb-3">Publications & Research</h2>
    <p class="reveal stagger-1 text-lg text-white/70 mb-12 max-w-2xl">
      Peer-reviewed contributions advancing the understanding of agile systems in healthcare.
    </p>

    <!-- Publication Cards -->
    <div class="space-y-6">
      {siteConfig.publications.map((pub, i) => (
        <div class={`reveal stagger-${i + 2} group rounded-xl bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition-colors`}>
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[var(--color-primary)]/20 text-[var(--color-primary-light)] border border-[var(--color-primary-light)]/20">
              {pub.journal}
            </span>
            <span class="font-mono-numbers text-xs text-white/50">{pub.year}</span>
            <span class="px-2 py-0.5 rounded text-xs text-white/40 bg-white/5">{pub.type}</span>
          </div>

          <h3 class="text-base md:text-lg font-bold text-white leading-snug mb-2">
            {pub.link ? (
              <a href={pub.link} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary-light)] transition-colors">
                {pub.title}
                <svg class="inline w-3.5 h-3.5 ml-1 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            ) : (
              <span>{pub.title}</span>
            )}
          </h3>

          <p class="text-sm text-white/50 mb-1">{pub.authors}</p>
          <p class="text-sm text-[var(--color-primary-light)]/70">{pub.detail}</p>
        </div>
      ))}
    </div>

    <!-- Research Interest Tags -->
    <div class="reveal mt-12 pt-8 border-t border-white/10">
      <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-white/40 mb-4">Research Interests</h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.researchInterests.map(interest => (
          <span class="skill-hover px-3 py-1.5 rounded-full text-xs font-medium bg-white/5 text-white/70 border border-white/10 hover:border-[var(--color-primary-light)]/40 hover:text-white">
            {interest}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
