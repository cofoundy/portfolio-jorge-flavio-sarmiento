---
import { siteConfig } from "../config";
---

<section id="experience" class="py-20 px-6" style="background-color: white">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-primary)] mb-12">Experience</h2>

    <!-- Vertical Timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-6 top-0 bottom-0 w-0.5 bg-[var(--color-primary-light)]/40"></div>

      <div class="space-y-10">
        {siteConfig.experience.map((exp, i) => (
          <div class={`reveal stagger-${Math.min(i + 1, 6)} relative pl-12 md:pl-16`}>
            <!-- Timeline dot -->
            <div class="absolute left-2.5 md:left-4.5 top-1.5 w-3 h-3 rounded-full bg-[var(--color-primary)] border-2 border-white shadow-sm"></div>

            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 md:gap-4">
              <div class="flex-1">
                <h3 class="text-base font-bold text-[var(--color-primary-dark)]">{exp.role}</h3>
                <p class="text-sm font-medium text-[var(--color-primary)]">{exp.org}</p>
              </div>
              <span class="font-mono-numbers text-xs text-[var(--color-primary-dark)]/50 shrink-0">{exp.period}</span>
            </div>

            <ul class="mt-3 space-y-1.5">
              {exp.bullets.map(bullet => (
                <li class="text-sm text-[var(--color-primary-dark)]/70 leading-relaxed flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-[var(--color-primary)] mt-2 shrink-0"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
