---
import { siteConfig } from "../config";
---

<footer id="contact" class="py-20 px-6" style={`background-color: var(--color-primary-dark); color: white`}>
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="reveal text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-primary-light)] mb-4">Let's Connect</h2>
    <p class="reveal stagger-1 text-white/60 text-sm max-w-md mx-auto mb-8">
      Open to research collaborations, speaking engagements, and academic partnerships.
    </p>

    <!-- Emails -->
    <div class="reveal stagger-2 flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white hover:bg-white/20 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {siteConfig.social.email}
      </a>
      <a
        href={`mailto:${siteConfig.social.emailInstitutional}`}
        class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white hover:bg-white/20 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        {siteConfig.social.emailInstitutional}
      </a>
    </div>

    <!-- Academic Profile Links -->
    <div class="reveal stagger-3 flex flex-wrap justify-center gap-4">
      {siteConfig.academicProfiles.map(profile => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="icon-hover w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white/70 hover:text-white hover:bg-white/20 transition-colors"
          title={profile.name}
        >
          {profile.icon === 'scholar' && (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>
          )}
          {profile.icon === 'researchgate' && (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.586 0c-1.873 0-3.291 1.418-3.291 3.291 0 1.873 1.418 3.291 3.291 3.291C21.458 6.582 23 5.164 23 3.291 23 1.418 21.458 0 19.586 0zM3.004 7.003c-1.654 0-3 1.346-3 3v4c0 1.654 1.346 3 3 3h1v-2h-1c-.551 0-1-.449-1-1v-4c0-.551.449-1 1-1h6c.551 0 1 .449 1 1v.5h2v-.5c0-1.654-1.346-3-3-3H3.004zm13.582 1.997c-2.757 0-5 2.243-5 5s2.243 5 5 5c1.613 0 3.043-.77 3.961-1.957l-1.586-1.175c-.585.756-1.468 1.132-2.375 1.132-1.654 0-3-1.346-3-3s1.346-3 3-3c.907 0 1.79.376 2.375 1.132l1.586-1.175c-.918-1.187-2.348-1.957-3.961-1.957z"/></svg>
          )}
          {profile.icon === 'orcid' && (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.387-.875-3.722-3.891-3.722h-2.428z"/></svg>
          )}
          {profile.icon === 'linkedin' && (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          )}
        </a>
      ))}
    </div>

    <!-- Copyright -->
    <p class="mt-12 text-xs text-white/30">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </p>
  </div>
</footer>
